{
  "name": "smartrec-backend",
  "version": "1.0.0",
  "description": "SmartRec backend — Shopify app server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/index.js",
    "db:migrate": "npx prisma db push --accept-data-loss",
    "db:generate": "npx prisma generate",
    "db:seed": "ts-node src/utils/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@shopify/shopify-api": "^11.2.0",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
