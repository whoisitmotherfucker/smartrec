{% comment %}
  SmartRec — AI Recommendations Block
  Placed on product pages via Shopify Online Store 2.0 theme editor.
  Fetches recommendations from the SmartRec API and renders them client-side.
{% endcomment %}

{% assign smartrec_heading = block.settings.heading | default: 'You might also like' %}
{% assign smartrec_count   = block.settings.products_count | default: 4 %}
{% assign smartrec_prices  = block.settings.show_prices | default: true %}
{% assign smartrec_atc     = block.settings.show_add_to_cart | default: true %}

<div
  id="smartrec-widget-{{ block.id }}"
  class="smartrec-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id | prepend: 'gid://shopify/Product/' }}"
  data-limit="{{ smartrec_count }}"
  data-show-prices="{{ smartrec_prices }}"
  data-show-atc="{{ smartrec_atc }}"
  data-heading="{{ smartrec_heading | escape }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%} Skeleton shown while JS loads {%- endcomment -%}
  <div class="smartrec-skeleton" aria-hidden="true">
    <div class="smartrec-skeleton__heading"></div>
    <div class="smartrec-skeleton__grid">
      {%- for i in (1..4) -%}
        <div class="smartrec-skeleton__card">
          <div class="smartrec-skeleton__image"></div>
          <div class="smartrec-skeleton__title"></div>
          <div class="smartrec-skeleton__price"></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  <div class="smartrec-content" style="display:none"></div>
</div>

<style>
  .smartrec-widget { margin: 2rem 0; font-family: inherit; }

  /* ── Skeleton ─────────────────────────────────────────────────────────── */
  @keyframes smartrec-shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position: 600px 0; }
  }
  .smartrec-skeleton__heading,
  .smartrec-skeleton__image,
  .smartrec-skeleton__title,
  .smartrec-skeleton__price {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 600px 100%;
    animation: smartrec-shimmer 1.4s infinite linear;
    border-radius: 4px;
  }
  .smartrec-skeleton__heading { height: 24px; width: 200px; margin-bottom: 1.25rem; }
  .smartrec-skeleton__grid    { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }
  .smartrec-skeleton__card    { display: flex; flex-direction: column; gap: 0.5rem; }
  .smartrec-skeleton__image   { aspect-ratio: 1; border-radius: 8px; }
  .smartrec-skeleton__title   { height: 14px; width: 80%; }
  .smartrec-skeleton__price   { height: 14px; width: 40%; }

  /* ── Widget ───────────────────────────────────────────────────────────── */
  .smartrec-heading { font-size: 1.25rem; font-weight: 600; margin-bottom: 1.25rem; }
  .smartrec-grid    { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }

  .smartrec-card    {
    display: flex; flex-direction: column; gap: 0.5rem;
    text-decoration: none; color: inherit;
    transition: transform 0.15s ease;
  }
  .smartrec-card:hover { transform: translateY(-2px); }

  .smartrec-card__image {
    aspect-ratio: 1; object-fit: cover;
    border-radius: 8px; background: #f5f5f5;
    width: 100%;
  }
  .smartrec-card__title { font-size: 0.9rem; line-height: 1.3; margin: 0; }
  .smartrec-card__price { font-size: 0.85rem; color: #555; margin: 0; }

  .smartrec-atc {
    margin-top: 0.35rem; padding: 0.5rem 0.75rem;
    background: var(--smartrec-primary, #000); color: #fff;
    border: none; border-radius: 4px; cursor: pointer;
    font-size: 0.8rem; font-family: inherit;
    transition: opacity 0.15s;
  }
  .smartrec-atc:hover { opacity: 0.85; }
</style>

<script>
(function () {
  const widget = document.getElementById('smartrec-widget-{{ block.id }}');
  if (!widget) return;

  const shop       = widget.dataset.shop;
  const productId  = widget.dataset.productId;
  const limit      = widget.dataset.limit || '4';
  const showPrices = widget.dataset.showPrices !== 'false';
  const showAtc    = widget.dataset.showAtc !== 'false';
  const heading    = widget.dataset.heading;
  const APP_URL    = {{ app.url | json }};

  // Generate a simple session ID for analytics
  const sid = sessionStorage.getItem('smartrec_sid') || Math.random().toString(36).slice(2);
  sessionStorage.setItem('smartrec_sid', sid);

  const apiUrl = `${APP_URL}/public/recommendations?shop=${encodeURIComponent(shop)}&productId=${encodeURIComponent(productId)}&limit=${limit}&sid=${sid}`;

  fetch(apiUrl)
    .then(r => r.json())
    .then(data => {
      const skeleton = widget.querySelector('.smartrec-skeleton');
      const content  = widget.querySelector('.smartrec-content');
      if (!data.recommendations || data.recommendations.length === 0) {
        skeleton.style.display = 'none';
        return;
      }

      const primaryColor = data.config?.primaryColor || '#000000';

      // Build HTML
      let html = `<h2 class="smartrec-heading">${heading || data.config?.title || 'You might also like'}</h2>`;
      html += `<div class="smartrec-grid">`;

      for (const product of data.recommendations) {
        const productUrl = `/products/${product.handle}`;
        const price = new Intl.NumberFormat(undefined, { style: 'currency', currency: '{{ cart.currency.iso_code }}' }).format(product.price);

        html += `
          <a class="smartrec-card" href="${productUrl}"
             data-product-id="${product.shopifyId}"
             onclick="smartrecTrackClick('${productId}', '${product.shopifyId}', '${sid}', '${shop}', '${APP_URL}')">
            ${product.imageUrl
              ? `<img class="smartrec-card__image" src="${product.imageUrl}" alt="${product.title}" loading="lazy" />`
              : `<div class="smartrec-card__image"></div>`}
            <p class="smartrec-card__title">${product.title}</p>
            ${showPrices && data.config?.showPrices !== false
              ? `<p class="smartrec-card__price">${price}</p>`
              : ''}
            ${showAtc && data.config?.showAddToCart !== false
              ? `<button class="smartrec-atc" style="background:${primaryColor}"
                   onclick="smartrecAddToCart(event, '${product.shopifyId}', '${productId}', '${sid}', '${shop}', '${APP_URL}')">
                   Add to cart
                 </button>`
              : ''}
          </a>`;
      }
      html += `</div>`;

      content.innerHTML = html;
      skeleton.style.display = 'none';
      content.style.display  = 'block';
    })
    .catch(() => {
      // Silently hide widget on error — never break the storefront
      widget.style.display = 'none';
    });

  // ── Event tracking helpers ─────────────────────────────────────────────────
  window.smartrecTrackClick = function (sourceId, targetId, sid, shop, appUrl) {
    navigator.sendBeacon(`${appUrl}/public/event`, JSON.stringify({
      shop, eventType: 'CLICK', sourceProductId: sourceId,
      targetProductId: targetId, sessionId: sid,
    }));
  };

  window.smartrecAddToCart = function (e, shopifyGid, sourceId, sid, shop, appUrl) {
    e.preventDefault();
    e.stopPropagation();
    const variantId = shopifyGid.replace('gid://shopify/Product/', '');
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 }),
    }).then(() => {
      navigator.sendBeacon(`${appUrl}/public/event`, JSON.stringify({
        shop, eventType: 'ADD_TO_CART', sourceProductId: sourceId,
        targetProductId: shopifyGid, sessionId: sid,
      }));
      // Trigger cart drawer if the theme has one
      document.dispatchEvent(new CustomEvent('cart:refresh'));
    });
  };
})();
</script>

{% schema %}
{
  "name": "SmartRec Recommendations",
  "target": "section",
  "templates": ["product"],
  "settings": [
    { "type": "text",    "id": "heading",          "label": "Heading",                      "default": "You might also like" },
    { "type": "range",   "id": "products_count",   "label": "Number of products",           "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "checkbox","id": "show_prices",       "label": "Show prices",                  "default": true },
    { "type": "checkbox","id": "show_add_to_cart",  "label": "Show Add to Cart button",      "default": true }
  ]
}
{% endschema %}
